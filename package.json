{
  "name": "liquidide",
  "private": true,
  "version": "0.1.0",
  "description": "LiquidIDE - browser-based IDE with sandboxed execution (MERN + BullMQ + Docker).",
  "workspaces": [
    "apps/*",
    "packages/*",
    "server"
  ],
  "scripts": {
    "dev": "concurrently -n api,worker,web -c blue,magenta,green \"npm run dev -w @liquidide/api\" \"npm run dev -w @liquidide/worker\" \"npm run dev -w @liquidide/web\"",
    "build": "npm install && npm run build -ws",
    "lint": "npm run lint -ws"
  },
  "devDependencies": {
    "@eslint/js": "^8.57.0",
    "concurrently": "^9.0.1",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.35.2",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.12",
    "vite": "^5.4.1",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.41",
    "tailwindcss": "^3.4.10"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}

