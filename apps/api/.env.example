PORT=8080
MONGO_URI=mongodb://root:rootpassword@localhost:27017/liquidide?authSource=admin
REDIS_URL=redis://localhost:6379

# CORS
WEB_ORIGIN=http://localhost:5173

# Auth (v0.2.7+)
JWT_SECRET=your_super_secret_jwt_key_at_least_32_chars
JWT_EXPIRES_IN=7d

# Social Login (OAuth)
# Get these from GitHub: https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Get these from Google Cloud Console: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# For local development: http://localhost:8080/api/auth
# For production: https://sam-compiler.onrender.com/api/auth
CALLBACK_URL_BASE=http://localhost:8080/api/auth

